// v3.mcp
// Write and readback a MADCAP config word using v3 mode. Do it!
//
    $display("V3_TEST.MCP running");
    #5000

// USAGE:  madcapTransaction(WRITE,mc_chip_id,mc_regmap_address,
//        mc_regmap_data);
//
//
    $display("Send MADCAP packet (enable v3 mode)");
    madcapTransaction(WRITE,3'b111,18,8'h03);

    $display("Send MADCAP packet -- write 0xF3 to reg 15");
    madcapTransaction(WRITE,3'b111,8'h0F,8'hF3);

    $display("Readback MADCAP config packet (reg 15, 0xF3 expected)");
    madcapTransaction(READ,3'b111,8'h0F,8'h00);
    
