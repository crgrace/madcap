// madcap_config_rw.mcp
// Write a config word to MADCAP and read it back
//

    #5000
    $display("Send Load Config Defaults command");
    chip_id = 2'01;
    regmap_address = 8'h04;
    regmap_data = 8'hF3;
    packet_declaration = 2'b10; // MADCAP config write
    make_madcap_packet = 1;
    @upstream_packet;
    make_madcap_packet = 0;
    #1000
    $display("Readback chip_id MADCAP config packet");
    $display("Expect data = 6'b00_0001"
    regmap_address = 8'h04;
    regmap_data = '0;
    packet_declaration = 2'b11; // MADCAP config read
    make_madcap_packet = 1;
    @upstream_packet;
    make_madcap_packet = 0;

