// madcap_config_rw.mcp
// Write a config word to MADCAP and read it back
//
    $display("MADCAP_CONFIG_RW.MCP running");
    #5000
    $display("Send MADCAP packet");
    mc_chip_id = 3'b111;
    mc_regmap_address = 8'h0F;
    mc_regmap_data = 8'hF3;
    mc_packet_declaration = 2'b10; // MADCAP config write
    make_madcap_packet = 1;
    @upstream_packet;
    make_madcap_packet = 0;
    #1000
    $display("Readback MADCAP config packet");
/*    mc_regmap_address = 8'h0F;
    mc_regmap_data = '0;
    mc_packet_declaration = 2'b11; // MADCAP config read
    make_madcap_packet = 1;
    @upstream_packet;
    make_madcap_packet = 0;
*/
