// madcap_config_rw.mcp
// Write a config word to MADCAP and read it back
//
    $display("MADCAP_CONFIG_RW.MCP running");
    #5000

// USAGE:  madcapTransaction(WRITE,mc_chip_id,mc_regmap_address,
//        mc_regmap_data);
//
//
    $display("Send MADCAP packet");
    madcapTransaction(WRITE,3'b111,8'h0F,8'hF3);

    $display("Readback MADCAP config packet");
    madcapTransaction(READ,3'b111,8'h0F,8'h00);
    
