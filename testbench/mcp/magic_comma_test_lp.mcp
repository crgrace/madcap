// magic_comma_test_lp.mcp
// Do the magic commas work for controlling LArPix?
//
    $display("MAGIC_COMMA_TEST_LP.MCP running");
    #5000

// USAGE:  madcapTransaction(WRITE,mc_chip_id,mc_regmap_address,
//        mc_regmap_data);
//

//    $display("Send MADCAP packet");
//    madcapTransaction(WRITE,2'b11,8'h0F,8'hF3);

//    $display("Test Trigger Request magic comma (K_R)");
//    make_lp_trigger_packet = 1;
//    #500
//    make_lp_trigger_packet = 0;
//    #1000
//

    $display("Enable Downstream PISO0 (REG 125)");
    $display("(for returning data to MADCAP)");
    larpixTransaction(WRITE,1,125,8'h01,0);    

    $display("write 10d to GLOBAL_THRESH (REG 64)");
    larpixTransaction(WRITE,1,64,8'h0a,0);

    $display("Read Back test GLOBAL_THRESH: 10d/0x0A expected");
    larpixTransaction(READ,1,64,8'h01,0);

    #200000
    $display("Test Soft Reset Request magic comma (K_R)");
    make_lp_soft_reset_packet = 1;
    #1500
    make_lp_soft_reset_packet = 0;
    #100000
    $display("Soft Reset request complete");
    $display("Read Back test GLOBAL_THRESH again: 10d/0x0A expected");
    larpixTransaction(READ,1,64,8'h01,0);

    #200000
    $display("Test Hard Reset Request magic comma (K_S)");
    make_lp_hard_reset_packet = 1;
    #1500
    make_lp_hard_reset_packet = 0;
    #100000

    $display("Enable Downstream PISO0 (REG 125)");
    $display("(for returning data to MADCAP)");
    larpixTransaction(WRITE,1,125,8'h01,0);    

    $display("Read Back GLOBAL_THRESH after hard reset: 255/0xFF expected");
    larpixTransaction(READ,1,64,8'h01,0);



 
