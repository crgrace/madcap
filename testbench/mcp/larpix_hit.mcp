// larpix_hit.mcp
// Get some hits from LArPix and read them out
//
    $display("LARPIX_HIT.MCP running");
    #5000

// USAGE:  madcapTransaction(WRITE,mc_chip_id,mc_regmap_address,
//        mc_regmap_data);
//

    $display("Send MADCAP packet to add data FIFO info in superpacket");
    madcapTransaction(WRITE,3'b111,5,8'h38);

// USAGE:  larpixTransaction(WRITE,lp_chip_id,lp_regmap_address,
//        lp_regmap_data,target_larpix);
//
//
    $display("Enable Downstream PISO0 (REG 125)");
    $display("(for returning data to MADCAP)");
    larpixTransaction(WRITE,1,125,8'h0F,0);    

#500 
  $display("enable channels 0 - 7 (enable CSA)");
  larpixTransaction(WRITE,1,66,8'hFF,0);

#500 
  $display("enable channels 0-7 (turn off channel mask)");
  larpixTransaction(WRITE,1,131,0,0);

#500 
  $display("enable channels 0 - 7  (turn off extern trigger mask)");
  larpixTransaction(WRITE,1,139,0,0);

#500 
  $display("disable hit veto");
  larpixTransaction(WRITE,1,128,0,0);

#100000 $display("HERE COMES THE BOOM!");
    external_trigger_larpix = 1;

#500
    external_trigger_larpix = 0;

