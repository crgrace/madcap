// lp_mc_v3.mcp
// Write and readback LArPix using v3 mode.
//
    $display("LP_MC_V3.MCP running");
    #5000

// USAGE:  madcapTransaction(WRITE,mc_chip_id,mc_regmap_address,
//        mc_regmap_data);
//
//
    $display("Send MADCAP packet (enable MADCAP v3 mode)");
    madcapTransaction(WRITE,3'b111,18,8'h03);

    $display("Put LArPix_v2c into v3 mode");
    larpixTransaction(WRITE,1,126,8'h1F,0);

    $display("write 10d to GLOBAL_THRESH (REG 64)");
    larpixTransaction(WRITE,1,64,8'h0a,0);

    $display("Read Back test GLOBAL_THRESH: 10d/0x0A expected");
    larpixTransaction(READ,1,64,8'h01,0);
    
